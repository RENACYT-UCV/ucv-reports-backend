# Copia este archivo como .env y rellena los valores reales
# cp .env.example .env

# Supabase PostgreSQL
# Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres

# JWT — genera con: openssl rand -base64 48
JWT_SECRET=CAMBIA_POR_UN_SECRETO_SEGURO
